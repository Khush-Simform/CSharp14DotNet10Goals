<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
	<TargetFramework>net10.0</TargetFramework>
	<Nullable>enable</Nullable>
	<ImplicitUsings>enable</ImplicitUsings>
	<LangVersion>14</LangVersion>
	<GenerateDocumentationFile>true</GenerateDocumentationFile>
	<NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
	<Compile Remove="CaManagement.Api\**" />
	<Content Remove="CaManagement.Api\**" />
	<EmbeddedResource Remove="CaManagement.Api\**" />
	<None Remove="CaManagement.Api\**" />
  </ItemGroup>

  <ItemGroup>
	<PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.4" />
	<PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.6" />
	<PackageReference Include="Swashbuckle.AspNetCore.Annotations" Version="10.1.6" />
  </ItemGroup>

</Project>
